{
  "name": "zcloak-agent",
  "version": "1.0.0",
  "description": "zCloak.ai Agent CLI — sign, verify, register and interact with ICP canisters via @dfinity JS SDK",
  "license": "MIT",
  "bin": {
    "zcloak-agent": "./dist/cli.js"
  },
  "main": "./dist/utils.js",
  "types": "./dist/utils.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "zcloak",
    "icp",
    "internet-computer",
    "dfinity",
    "agent",
    "sign",
    "canister"
  ],
  "dependencies": {
    "@dfinity/agent": "^3.4.3",
    "@dfinity/candid": "^3.4.3",
    "@dfinity/identity": "^3.4.3",
    "@dfinity/identity-secp256k1": "^3.4.3",
    "@dfinity/principal": "^3.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
